.program hpil_debug_1hz

.wrap_target
    ; Toggle LED
    set y, 31
high_outer:
        set x, 31
high_inner:
            set pins, 1 [3]
            jmp x--, high_inner
        jmp y--, high_outer
    
    set y, 31
low_outer:
        set x, 31
low_inner:
            set pins, 0 [3]
            jmp x--, low_inner
        jmp y--, low_outer
.wrap
